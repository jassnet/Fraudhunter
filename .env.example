# Backend
ACS_BASE_URL=https://acs.example.com/api
ACS_ACCESS_KEY=your_access_key
ACS_SECRET_KEY=your_secret_key
# Alternatively: ACS_TOKEN=access_key:secret_key

# PostgreSQL (required)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fraudchecker

# Security
FC_ADMIN_API_KEY=change_me
# Local: use dev (read posture relaxed). Production on Render: set FC_ENV=production and exactly one of
# FC_REQUIRE_READ_AUTH, FC_EXTERNAL_READ_PROTECTION, or FC_ALLOW_PUBLIC_READ.
FC_ENV=dev
FC_ALLOW_INSECURE_ADMIN=false
FC_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ACS_ALLOW_INSECURE=false
FRAUD_TIMEZONE=Asia/Tokyo

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8001
