{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "types": [
      "node"
    ]
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
